# Ghost Schema — environment variables
# Copy to .env and fill in your keys. Never commit .env to git.

# ── Anthropic / Claude Code ───────────────────────────────────────────────────
# Claude Code CLI (the Architect subprocess) needs Anthropic credentials.
#
# LOCAL DEV: if you are already running Claude Code interactively, authentication
# is handled via stored OAuth sessions in ~/.claude/ — you do NOT need this key
# locally. The subprocess inherits the same auth automatically.
#
# DOCKER / AWS: containers have no ~/.claude/ directory, so ANTHROPIC_API_KEY
# must be set explicitly. Get it at: https://console.anthropic.com
#
# ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini ────────────────────────────────────────────────────────────────────
# Used by the inference scripts that Claude Code writes and runs.
# These scripts call Gemini Flash in parallel for row-level classification.
# Required in all environments (local and Docker).
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── Model ─────────────────────────────────────────────────────────────────────
# Claude model used by the Architect subprocess. Pinned so quality is identical
# whether auth is OAuth (local) or API key (Docker/AWS).
# ARCHITECT_MODEL=claude-sonnet-4-6   # default
# ARCHITECT_MODEL=claude-opus-4-5     # more capable, higher cost

# ── Storage ───────────────────────────────────────────────────────────────────
# Where project databases are stored. Each project = one .db file here.
# In Docker/AWS, mount an EBS volume at /app/data and set this accordingly.
GHOST_DATA_DIR=data
